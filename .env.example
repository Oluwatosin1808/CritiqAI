# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project settings (Settings → API)

# Your Supabase project URL
# Example: https://abcdefghijk.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (safe to expose, for client-side operations)
# Found under: Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-here

# Supabase Service Role Key (SECRET - server-side only)
# Found under: Settings → API → service_role secret
# ⚠️ KEEP THIS SECRET - Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-here

# ============================================================================
# GEMINI API CONFIGURATION
# ============================================================================
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey

# Gemini API Key for design analysis
# ⚠️ KEEP THIS SECRET
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# OPTIONAL: DEVELOPMENT CONFIGURATION
# ============================================================================

# Next.js environment (development, production, test)
NODE_ENV=development

# Enable debug logging (set to true for verbose logs)
DEBUG=false
